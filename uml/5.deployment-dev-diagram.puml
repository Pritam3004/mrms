@startuml DeploymentDev
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Deployment.puml

LAYOUT_TOP_DOWN()

'AddNodeTag("tenantzone", $borderColor="#666666", $borderStyle=DashedLine(), $bgColor="#e3e2dc", $legendText="Tenant Zone")
AddBoundaryTag("appzone", $borderColor="#1168bd", $borderStyle=DashedLine(), $bgColor="#ebe7e7", $legendText="Application Zone")
AddBoundaryTag("backendzone", $borderColor="#666666", $borderStyle=DashedLine(), $bgColor="#eae6f7", $legendText="Backend Zone")
AddElementTag("black", $bgColor="#000000", $fontColor="#ffffff", $borderColor="#ffffff")
AddElementTag("external", $bgColor="#999999", $fontColor="#ffffff", $borderColor="#ffffff")


title MRMS - C4 Level 3: Deployment (Development)

'---- Client ----
Deployment_Node(clientBrowser, "Client", "Web Browser") {
    Person(users, "Users (Browser)", "Staff who enter, review,\nand approve resolutions.")
    Person(roles, "Administrator (Browser)", "Manages SharePoint\ngroup-based permission roles.")
}

Person(userEmail, "Users (Email)", "Sends Email with documents to MRMS.")

'---- UN Microsoft 365 Tenant ----
Deployment_Node(m365Tenant, "UN Microsoft Tenant", "UN OICT - unitednations.sharepoint.com") {

    Deployment_Node(entraNode, "UN Entra ID", "OAuth 2.0", $tags="black") {
        Container(entraID, "Identity Provider", "Entra ID", "SSO authentication\nfor MRMS users.", $tags="black")
    }

    Container(mailboxDev, "staging-mrms@un.org", "Shared Mailbox", "Ingestion mailbox for\nincoming resolutions via email (with safe list).", $tags="external")

    '---- Application Zone (logical) ----
    Boundary(appZone, "Application Zone") {

        Deployment_Node(spoNode, "SharePoint Online", "Microsoft 365 SaaS - Dev/QA Site Collection") {
            Container(sharePointOnlineDev, "SharePoint Online (SPFx)", "SharePoint SPFx", "Web parts: data entry, resolution\nmanagement, dashboards, OS generation.")
        }

        Deployment_Node(paNode, "Power Platform", "Microsoft 365 - Environment") {
            Container(powerAutomateDev, "Power Automate", "Flows - Dev/QA", "Email ingestion, approvals,\nnotifications, OP extraction,\nand bulk operations.")
        }

        Deployment_Node(azureTenant, "Microsoft Azure", "UN Azure Subscription - Consumption Plan") {
            Container(azFuncDev, "Azure Function Dev/QA API", "Python 3.11", "OS generation, OP extraction,\nRevised Estimate report generation.")
        }
    }

    '---- Backend Zone (logical) ----
    Boundary(backendZone, "Backend Zone") {
        Deployment_Node(spoBackendNode, "SharePoint Online", "Microsoft 365 SaaS - Data Layer") {
            ContainerDb(listsLibrariesDev, "Lists & Libraries", "SharePoint Lists", "Resolutions, Mandates, OPs,\nPBI lists, CostRates, SafeList, Error Logs.")
        }
    }
}

'---- External ----
Deployment_Node(docUNNode, "documents.un.org", "External - UN Document Repository", $tags="external") {
    Container(docUN, "UN Official Documents System", "HTTPS / POST", "Source for adopted resolution documents.", $tags="external")
}

'---- Relationships ----
Rel_D(users, entraID, "Authenticates", "OAuth 2.0")
Rel_D(roles, entraID, "Authenticates", "OAuth 2.0")
Rel_D(users, sharePointOnlineDev, "Interacts", "HTTPS")
Rel_D(roles, sharePointOnlineDev, "Configures permissions", "HTTPS")

BiRel(sharePointOnlineDev, listsLibrariesDev, "SharePoint REST API", "HTTPS / POST")

Rel_D(powerAutomateDev, mailboxDev, "Monitors mailbox for SafeList-filtered emails", "PULL / Flow trigger")
Rel_U(userEmail, mailboxDev, "Sends email with Formatted Subject and attachments", "Flow trigger")
Rel_L(powerAutomateDev, azFuncDev, "Calls", "HTTPS / POST")
Rel_R(sharePointOnlineDev, azFuncDev, "Calls", "HTTPS / POST")
Rel_R(powerAutomateDev, listsLibrariesDev, "SharePoint REST API", "HTTPS / POST")

Rel_D(azFuncDev, listsLibrariesDev, "SharePoint REST API/ Auth - ClientID and ClientSecret", "HTTPS / POST")
Rel_D(azFuncDev, docUN, "Reads", "HTTPS / PULL")

SHOW_LEGEND()
@enduml